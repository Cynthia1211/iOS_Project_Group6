# ==========================================
# Xcode 和 苹果系统 核心缓存（全组起冲突的罪魁祸首）
# ==========================================
.DS_Store
*.swp
*~
build/
DerivedData/
*.hmap
*.xccheckout
*.xcworkspace
!default.xcworkspace

# ==========================================
# 个人用户状态文件（每个人看代码的窗口位置、历史记录，绝不能传）
# ==========================================
xcuserdata/
*.xcuserdatad
*.xcuserstate

# ==========================================
# 依赖管理（如果你们后面用 CocoaPods 引入第三方 SDK 的话）
# ==========================================
Pods/
Podfile.lock
.swiftpm/
.build/

# ==========================================
# 编译产物与打包文件
# ==========================================
*.framework
*.xcworkspace
*.xcarchive
*.ipa
*.dSYM